        "import seaborn as sns\n",
        "import pandas as pd\n",
        "\n",
        "# Load Titanic dataset\n",
        "titanic_data = sns.load_dataset('titanic')\n",
        "\n",
        "# Display the first few records\n",
        "print(titanic_data.head())\n",
        "\n",
        "# Review the structure of the dataset\n",
        "print(titanic_data.info())\n",
        "\n",
        "print(titanic_data.describe())\n",
        "\n",
        "# Check missing values\n",
        "print(titanic_data.isnull().sum())\n",
        "\n",
        "# Clean the data\n",
        "mean_value = round(titanic_data['age'].mean())\n",
        "mode_value = titanic_data['embarked'].mode()[0]\n",
        "\n",
        "titanic_data = titanic_data.fillna(value={'age': mean_value, 'embarked': mode_value})\n",
        "titanic_data = titanic_data.dropna(axis=1)\n",
        "\n",
        "# Confirm no missing values remain\n",
        "print(titanic_data.isnull().sum())\n",
        "\n",
        "# Correlation analysis\n",
        "correlation = titanic_data[['age', 'fare']].corr()\n",
        "print(correlation)\n",
        "\n",
        "# Cross-tabulation of survival by passenger class\n",
        "cross_tab = pd.crosstab(titanic_data['pclass'], titanic_data['survived'])\n",
        "print(cross_tab)"
      ]
